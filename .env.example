# ══════════════════════════════════════════════════════════
# TodoMovil Agente CRM — Variables de entorno
# Copiar a .env y completar los valores reales
# ══════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=todomovil
POSTGRES_USER=tm_user
POSTGRES_PASSWORD=tm_secure_2025
DATABASE_URL=postgresql://tm_user:tm_secure_2025@localhost:5432/todomovil

# ── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── LLM (z-ai-web-dev-sdk / GLM) ─────────────────────────
ZAI_API_KEY=your_zai_api_key_here
LLM_MODEL=glm-4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── Embeddings ────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# ── FastAPI ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Next.js ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Nginx / Dominio ──────────────────────────────────────
DOMAIN=todomovil-agente.com
SSL_EMAIL=admin@todomovil-agente.com

# ── Seguridad ─────────────────────────────────────────────
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRATION_HOURS=24

# ── RAG ──────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.65
RAG_CERTAINTY_HIGH=0.85
RAG_CERTAINTY_MEDIUM=0.65

# ── Web Search (capa 2) ──────────────────────────────────
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
